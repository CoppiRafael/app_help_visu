# --------------------------------------------------
# Python artifacts
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --------------------------------------------------
# Virtual environments
# --------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/

# --------------------------------------------------
# IDEs and editors
# --------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --------------------------------------------------
# macOS / Windows
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Dotenv files
# --------------------------------------------------
# – ignore todos os .env reais e variações:
.env
.env.*
# – permitir apenas o template de exemplo:
!.env.example

# --------------------------------------------------
# Streamlit (caso você venha a usar secrets.toml)
# --------------------------------------------------
.streamlit/secrets.toml

# --------------------------------------------------
# Logs, reports e caches
# --------------------------------------------------
*.log
htmlcov/
.coverage
pip-wheel-metadata/

# --------------------------------------------------
# Artefatos de build / distribuições
# --------------------------------------------------
build/
dist/
*.egg-info/

# --------------------------------------------------
# Bancos de dados locais
# --------------------------------------------------
*.sqlite3
*.db
